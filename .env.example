# scrapehub configuration — copy to `.env` and edit. NEVER commit a real .env.
# All variables are optional; sane defaults are baked into config.py.

# Comma-separated proxy URLs. The pool rotates and health-checks these.
# Ships empty: supply your OWN trustworthy proxies. Example:
# SCRAPEHUB_PROXIES=http://user:pass@host1:8080,http://user:pass@host2:8080
SCRAPEHUB_PROXIES=

# Bounded concurrency for async batching (max in-flight requests).
SCRAPEHUB_CONCURRENCY=8

# Batch size used when chunking large id/url lists.
SCRAPEHUB_BATCH_SIZE=20

# Per-host polite rate limit (requests per second) for the token bucket.
SCRAPEHUB_RATE_LIMIT=4.0

# Token bucket burst capacity.
SCRAPEHUB_RATE_BURST=8

# HTTP/browser timeout in seconds.
SCRAPEHUB_TIMEOUT=30.0

# Max retry attempts for transient failures.
SCRAPEHUB_MAX_RETRIES=4

# Where CSV/JSON exports are written.
SCRAPEHUB_OUTPUT_DIR=data

# Logging: "json" for machine-readable, "console" for pretty dev output.
SCRAPEHUB_LOG_FORMAT=console

# Log level: DEBUG, INFO, WARNING, ERROR.
SCRAPEHUB_LOG_LEVEL=INFO
